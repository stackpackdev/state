{
  "name": "stackpack-state",
  "version": "0.1.2",
  "description": "Agent-optimized React state management using Together/Separate/When/Gate primitives",
  "type": "module",
  "main": "dist/runtime/core/index.js",
  "types": "dist/runtime/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/runtime/core/index.js",
      "types": "./dist/runtime/core/index.d.ts"
    },
    "./react": {
      "import": "./dist/runtime/react/index.js",
      "types": "./dist/runtime/react/index.d.ts"
    },
    "./components": {
      "import": "./dist/runtime/components/index.js",
      "types": "./dist/runtime/components/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --exclude 'demo-app/**' --exclude 'demo-app-sa/**' --exclude 'demo-app-sa-in-folder-refactor/**'",
    "bench": "vitest bench",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "state-management",
    "react",
    "ai",
    "agent",
    "zod",
    "immer",
    "state-machine",
    "stackpack",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackpackdev/state.git"
  },
  "homepage": "https://github.com/stackpackdev/state",
  "bugs": {
    "url": "https://github.com/stackpackdev/state/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "immer": "^10.0.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist/runtime/core/*.js",
    "dist/runtime/core/*.js.map",
    "dist/runtime/core/*.d.ts",
    "dist/runtime/core/*.d.ts.map",
    "dist/runtime/react",
    "dist/runtime/components",
    "skill/",
    "SKILL.md",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT"
}
