{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "paths": {
      "stackpack-state": ["./runtime/core/index.ts"],
      "stackpack-state/react": ["./runtime/react/index.ts"],
      "stackpack-state/components": ["./runtime/components/index.ts"]
    }
  },
  "include": ["runtime/**/*.ts", "runtime/**/*.tsx"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
